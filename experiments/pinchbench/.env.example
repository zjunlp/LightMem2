# PinchBench migrated method-path runtime configuration

# Required: define one route per short model alias you actually run.
# The key names are:
#   PINCHBENCH_MODEL_<MODEL_NAME>_BASE_URL
#   PINCHBENCH_MODEL_<MODEL_NAME>_API_KEY
#   PINCHBENCH_MODEL_<MODEL_NAME>_PROVIDER_PREFIX   (optional)
#
# Example model-name normalization:
#   gpt-5.4-mini       -> GPT_5_4_MINI
#   qwen3.5-35b-a3b    -> QWEN3_5_35B_A3B
PINCHBENCH_MODEL_GPT_5_4_MINI_BASE_URL=https://your-openai-compatible-endpoint.example/v1
PINCHBENCH_MODEL_GPT_5_4_MINI_API_KEY=replace-me
PINCHBENCH_MODEL_GPT_5_4_MINI_PROVIDER_PREFIX=provider

PINCHBENCH_MODEL_QWEN3_5_35B_A3B_BASE_URL=https://your-other-openai-compatible-endpoint.example/v1
PINCHBENCH_MODEL_QWEN3_5_35B_A3B_API_KEY=replace-me
PINCHBENCH_MODEL_QWEN3_5_35B_A3B_PROVIDER_PREFIX=provider

# Optional global fallback when a model-specific route is not present.
# New name first, legacy fallback still supported.
TOKENPILOT_BASE_URL=
TOKENPILOT_API_KEY=
ECOCLAW_BASE_URL=
ECOCLAW_API_KEY=
PINCHBENCH_MODEL_PROVIDER_PREFIX=

# Optional explicit dataset path override.
# The migrated mainline defaults to experiments/pinchbench/dataset and should not
# point back to the external bench repository.
PINCHBENCH_DATASET_DIR=/path/to/tokenpilot/experiments/pinchbench/dataset

# Optional method-path defaults.
TOKENPILOT_MODEL=tokenpilot/gpt-5.4-mini
TOKENPILOT_JUDGE=tokenpilot/gpt-5.4-mini
TOKENPILOT_SUITE=automated-only
TOKENPILOT_RUNS=1
TOKENPILOT_TIMEOUT_MULTIPLIER=1.0
TOKENPILOT_PARALLEL=1
TOKENPILOT_SESSION_MODE=isolated
TOKENPILOT_FORCE_GATEWAY_RESTART=true
ECOCLAW_MODEL=ecoclaw/gpt-5.4-mini
ECOCLAW_JUDGE=ecoclaw/gpt-5.4-mini
ECOCLAW_SUITE=automated-only
ECOCLAW_RUNS=1
ECOCLAW_TIMEOUT_MULTIPLIER=1.0
ECOCLAW_PARALLEL=1
ECOCLAW_SESSION_MODE=isolated
ECOCLAW_FORCE_GATEWAY_RESTART=true

# Optional baseline defaults.
TOKENPILOT_BASELINE_MODEL=gpt-5.4-mini
TOKENPILOT_BASELINE_JUDGE=gpt-5.4-mini
TOKENPILOT_BASELINE_SUITE=automated-only
TOKENPILOT_BASELINE_RUNS=1
TOKENPILOT_BASELINE_TIMEOUT_MULTIPLIER=1.0
TOKENPILOT_BASELINE_PARALLEL=1
TOKENPILOT_BASELINE_SESSION_MODE=isolated
BASELINE_MODEL=gpt-5.4-mini
BASELINE_JUDGE=gpt-5.4-mini

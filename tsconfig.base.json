{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "strict": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "dist",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "baseUrl": ".",
        "paths": {
            "@tokenpilot/kernel": [
                "components/tokenpilot/packages/kernel/src/index.ts"
            ],
            "@tokenpilot/artifact-store": [
                "components/tokenpilot/packages/foundation/artifact-store/src/index.ts"
            ],
            "@tokenpilot/decision": [
                "components/tokenpilot/packages/layers/decision/src/index.ts"
            ],
            "@tokenpilot/history": [
                "components/tokenpilot/packages/layers/history/src/index.ts"
            ],
            "@tokenpilot/memory": [
                "components/tokenpilot/packages/layers/memory/src/index.ts"
            ],
            "@tokenpilot/runtime-core": [
                "components/tokenpilot/packages/runtime-core/src/index.ts"
            ],
            "@tokenpilot/reduction": [
                "components/tokenpilot/packages/features/reduction/src/index.ts"
            ],
            "@tokenpilot/eviction": [
                "components/tokenpilot/packages/features/eviction/src/index.ts"
            ],
            "@tokenpilot/host-adapter": [
                "components/tokenpilot/packages/host-adapter/src/index.ts"
            ],
            "@tokenpilot/stabilizer": [
                "components/tokenpilot/packages/features/stabilizer/src/index.ts"
            ],
            "@tokenpilot/product-surface": [
                "components/tokenpilot/packages/product-surface/src/index.ts"
            ],
            "@tokenpilot/mcp": [
                "components/tokenpilot/products/mcp/src/index.ts"
            ]
        },
        "types": [
            "node"
        ]
    }
}

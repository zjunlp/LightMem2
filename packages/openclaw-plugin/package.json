{
  "name": "ecoclaw",
  "version": "0.1.0",
  "description": "EcoClaw plugin for OpenClaw: routing hooks and token-efficiency runtime controls.",
  "main": "dist/index.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Xubqpanda/EcoClaw.git",
    "directory": "packages/openclaw-plugin"
  },
  "files": [
    "dist/index.js",
    "dist/index.js.map",
    "dist/semantic-llmlingua2-worker.py",
    "openclaw.plugin.json",
    "README.md",
    "scripts/acceptance_report.sh",
    "scripts/compaction_e2e.sh",
    "scripts/e2e.sh",
    "scripts/summary_e2e.sh",
    "scripts/semantic_e2e.sh",
    "scripts/cache_acceptance.sh",
    "fixtures/responses-cache-bridge-session.jsonl"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsx build.ts",
    "test": "node --import tsx --test src/**/*.test.ts",
    "pack:release": "bash ./scripts/pack_release.sh",
    "install:release": "bash ./scripts/install_release.sh",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "acceptance:e2e": "bash ./scripts/e2e.sh",
    "acceptance:cache": "bash ./scripts/cache_acceptance.sh",
    "acceptance:compaction": "bash ./scripts/compaction_e2e.sh",
    "acceptance:report": "bash ./scripts/acceptance_report.sh",
    "acceptance:summary": "bash ./scripts/summary_e2e.sh",
    "acceptance:semantic": "bash ./scripts/semantic_e2e.sh",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "esbuild": "^0.25.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "ecoclaw",
    "llm-routing",
    "token-efficiency"
  ]
}

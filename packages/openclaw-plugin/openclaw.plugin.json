{
  "id": "ecoclaw",
  "kind": "runtime",
  "name": "EcoClaw Runtime Optimizer",
  "version": "0.1.0",
  "description": "Token-efficiency runtime plugin for OpenClaw with pluggable routing and optimization hooks.",
  "author": "EcoClaw",
  "homepage": "https://github.com/Xubqpanda/EcoClaw",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "description": "Enable EcoClaw plugin hooks."
      },
      "logLevel": {
        "type": "string",
        "enum": [
          "info",
          "debug"
        ],
        "default": "info",
        "description": "Plugin log verbosity."
      },
      "proxyBaseUrl": {
        "type": "string",
        "description": "Optional OpenAI-compatible proxy base URL for routing (for example: http://127.0.0.1:8787/v1)."
      },
      "proxyApiKey": {
        "type": "string",
        "description": "Optional API key used with proxyBaseUrl.",
        "sensitive": true
      },
      "stateDir": {
        "type": "string",
        "description": "Directory for EcoClaw plugin state (default: ~/.openclaw/ecoclaw-plugin-state)."
      },
      "debugTapProviderTraffic": {
        "type": "boolean",
        "default": false,
        "description": "Debug only: tap outbound provider fetch requests/responses and write JSONL records."
      },
      "debugTapPath": {
        "type": "string",
        "description": "Path for provider traffic tap JSONL output."
      },
      "proxyAutostart": {
        "type": "boolean",
        "default": true,
        "description": "Autostart embedded responses proxy when plugin starts."
      },
      "proxyPort": {
        "type": "number",
        "default": 17667,
        "description": "Embedded responses proxy listen port."
      },
      "modules": {
        "type": "object",
        "additionalProperties": false,
        "description": "Module-level switches for ablation and controlled experiments.",
        "properties": {
          "stabilizer": {
            "type": "boolean",
            "default": true,
            "description": "Enable stabilizer telemetry module."
          },
          "policy": {
            "type": "boolean",
            "default": true,
            "description": "Enable decision/policy module."
          },
          "summary": {
            "type": "boolean",
            "default": true,
            "description": "Enable summary execution module."
          },
          "reduction": {
            "type": "boolean",
            "default": true,
            "description": "Enable reduction execution module."
          },
          "compaction": {
            "type": "boolean",
            "default": true,
            "description": "Enable compaction execution module."
          },
          "handoff": {
            "type": "boolean",
            "default": true,
            "description": "Enable handoff execution module."
          },
          "decisionLedger": {
            "type": "boolean",
            "default": true,
            "description": "Enable decision ledger reporting module."
          }
        }
      },
      "compaction": {
        "type": "object",
        "additionalProperties": false,
        "description": "Compaction and summary controls for the shadow runtime pipeline.",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "autoForkOnPolicy": {
            "type": "boolean",
            "default": true,
            "description": "Apply generated compaction plans by forking a new shadow physical session."
          },
          "summaryGenerationMode": {
            "type": "string",
            "enum": ["llm_full_context", "heuristic"],
            "default": "heuristic"
          },
          "summaryFallbackToHeuristic": {
            "type": "boolean",
            "default": true
          },
          "summaryMaxOutputTokens": {
            "type": "number",
            "description": "Max output tokens for summary sidecar generation."
          },
          "includeAssistantReply": {
            "type": "boolean",
            "default": true
          },
          "summaryPrompt": {
            "type": "string",
            "description": "Inline summary prompt override used by the summary module."
          },
          "summaryPromptPath": {
            "type": "string",
            "description": "Path to a custom summary prompt file."
          },
          "resumePrefixPrompt": {
            "type": "string",
            "description": "Inline resume-prefix prompt override used when seeding compacted branches."
          },
          "resumePrefixPromptPath": {
            "type": "string",
            "description": "Path to a custom resume-prefix prompt file."
          },
          "compactionCooldownTurns": {
            "type": "number",
            "description": "Cooldown turns after a compaction request before another request is allowed."
          },
          "turnLocalCompaction": {
            "type": "object",
            "additionalProperties": false,
            "description": "Turn-local compaction settings for archiving tool results that have been consumed by subsequent writes.",
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": false,
                "description": "Enable turn-local compaction."
              },
              "archiveDir": {
                "type": "string",
                "description": "Directory to store archived tool results."
              }
            }
          }
        }
      },
      "handoff": {
        "type": "object",
        "additionalProperties": false,
        "description": "Task handoff generation controls for future sub-agent or continuation workflows.",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "handoffGenerationMode": {
            "type": "string",
            "enum": ["llm_full_context", "heuristic"],
            "default": "heuristic"
          },
          "handoffFallbackToHeuristic": {
            "type": "boolean",
            "default": true
          },
          "handoffMaxOutputTokens": {
            "type": "number",
            "description": "Max output tokens for handoff sidecar generation."
          },
          "includeAssistantReply": {
            "type": "boolean",
            "default": true
          },
          "handoffPrompt": {
            "type": "string",
            "description": "Inline handoff prompt override used by the handoff module."
          },
          "handoffPromptPath": {
            "type": "string",
            "description": "Path to a custom handoff prompt file."
          },
          "handoffCooldownTurns": {
            "type": "number",
            "description": "Cooldown turns after a handoff request before another request is allowed."
          }
        }
      },
      "semanticReduction": {
        "type": "object",
        "additionalProperties": false,
        "description": "Optional semantic LLMLingua2 reduction settings for after-call compression.",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "pythonBin": {
            "type": "string",
            "description": "Python executable used to run the LLMLingua2 worker."
          },
          "timeoutMs": {
            "type": "number",
            "default": 120000
          },
          "llmlinguaModelPath": {
            "type": "string",
            "description": "Local path to the LLMLingua2 token-classification model."
          },
          "targetRatio": {
            "type": "number",
            "description": "Target semantic keep ratio between 0.05 and 0.95."
          },
          "minInputChars": {
            "type": "number",
            "description": "Minimum response length before semantic reduction is attempted."
          },
          "minSavedChars": {
            "type": "number",
            "description": "Minimum saved characters required to accept semantic reduction."
          },
          "preselectRatio": {
            "type": "number",
            "description": "Chunk preselection ratio before LLMLingua2 compression."
          },
          "maxChunkChars": {
            "type": "number",
            "description": "Chunk size used by semantic reduction worker."
          },
          "embedding": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "provider": {
                "type": "string",
                "enum": ["local", "api", "none"],
                "default": "none"
              },
              "modelPath": {
                "type": "string",
                "description": "Local path to the embedding model when provider=local."
              },
              "apiBaseUrl": {
                "type": "string",
                "description": "OpenAI-compatible embeddings base URL when provider=api."
              },
              "apiKey": {
                "type": "string",
                "sensitive": true,
                "description": "API key for embeddings when provider=api."
              },
              "apiModel": {
                "type": "string",
                "description": "Embedding model name when provider=api."
              },
              "requestTimeoutMs": {
                "type": "number",
                "default": 30000
              }
            }
          }
        }
      }
    }
  },
  "uiHints": {
    "enabled": {
      "label": "Enabled"
    },
    "logLevel": {
      "label": "Log Level"
    },
    "proxyBaseUrl": {
      "label": "Proxy Base URL",
      "placeholder": "http://127.0.0.1:8787/v1"
    },
    "proxyApiKey": {
      "label": "Proxy API Key",
      "sensitive": true
    },
    "stateDir": {
      "label": "State Directory"
    },
    "debugTapProviderTraffic": {
      "label": "Debug Tap Provider Traffic"
    },
    "debugTapPath": {
      "label": "Debug Tap Path"
    },
    "proxyAutostart": {
      "label": "Proxy Autostart"
    },
    "proxyPort": {
      "label": "Proxy Port"
    },
    "compaction": {
      "label": "Compaction"
    },
    "handoff": {
      "label": "Handoff"
    },
    "semanticReduction": {
      "label": "Semantic Reduction"
    }
  }
}

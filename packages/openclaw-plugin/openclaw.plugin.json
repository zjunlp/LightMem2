{
  "id": "ecoclaw",
  "kind": "runtime",
  "name": "EcoClaw Runtime Optimizer",
  "version": "0.1.0",
  "description": "Token-efficiency runtime plugin for OpenClaw with pluggable routing and optimization hooks.",
  "author": "EcoClaw",
  "homepage": "https://github.com/Xubqpanda/EcoClaw",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "description": "Enable EcoClaw plugin hooks."
      },
      "logLevel": {
        "type": "string",
        "enum": [
          "info",
          "debug"
        ],
        "default": "info",
        "description": "Plugin log verbosity."
      },
      "proxyBaseUrl": {
        "type": "string",
        "description": "Optional OpenAI-compatible proxy base URL for routing (for example: http://127.0.0.1:8787/v1)."
      },
      "proxyApiKey": {
        "type": "string",
        "description": "Optional API key used with proxyBaseUrl.",
        "sensitive": true
      },
      "stateDir": {
        "type": "string",
        "description": "Directory for EcoClaw plugin state (default: ~/.openclaw/ecoclaw-plugin-state)."
      },
      "debugTapProviderTraffic": {
        "type": "boolean",
        "default": false,
        "description": "Debug only: tap outbound provider fetch requests/responses and write JSONL records."
      },
      "debugTapPath": {
        "type": "string",
        "description": "Path for provider traffic tap JSONL output."
      },
      "proxyAutostart": {
        "type": "boolean",
        "default": true,
        "description": "Autostart embedded responses proxy when plugin starts."
      },
      "proxyPort": {
        "type": "number",
        "default": 17667,
        "description": "Embedded responses proxy listen port."
      },
      "proxyMode": {
        "type": "object",
        "additionalProperties": false,
        "description": "Proxy behavior controls. pureForward=true keeps proxy as transport-only without request/response rewriting.",
        "properties": {
          "pureForward": {
            "type": "boolean",
            "default": false,
            "description": "When true, disable proxy-side stability/reduction rewrites and only forward traffic."
          }
        }
      },
      "hooks": {
        "type": "object",
        "additionalProperties": false,
        "description": "Official hook integration switches.",
        "properties": {
          "beforeToolCall": {
            "type": "boolean",
            "default": true,
            "description": "Enable before_tool_call default safety parameter injection."
          },
          "toolResultPersist": {
            "type": "boolean",
            "default": true,
            "description": "Enable tool_result_persist artifact externalization for oversized tool results."
          }
        }
      },
      "contextEngine": {
        "type": "object",
        "additionalProperties": false,
        "description": "Canonical-state context engine settings.",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "pruneThresholdChars": {
            "type": "number",
            "default": 100000,
            "description": "When estimated canonical chars exceed this threshold, prune older tool results."
          },
          "keepRecentToolResults": {
            "type": "number",
            "default": 5,
            "description": "Number of latest tool results to keep unpruned in canonical state."
          },
          "placeholder": {
            "type": "string",
            "default": "[pruned]",
            "description": "Placeholder text used when canonical pruning rewrites old tool results."
          }
        }
      },
      "modules": {
        "type": "object",
        "additionalProperties": false,
        "description": "Module-level switches for ablation and controlled experiments.",
        "properties": {
          "stabilizer": {
            "type": "boolean",
            "default": true,
            "description": "Enable stabilizer telemetry module."
          },
          "policy": {
            "type": "boolean",
            "default": true,
            "description": "Enable decision/policy module."
          },
          "reduction": {
            "type": "boolean",
            "default": true,
            "description": "Enable reduction execution module."
          },
          "compaction": {
            "type": "boolean",
            "default": true,
            "description": "Enable event-driven compaction execution module."
          },
          "eviction": {
            "type": "boolean",
            "default": false,
            "description": "Enable eviction execution module interface (currently noop scaffold)."
          },
          "decisionLedger": {
            "type": "boolean",
            "default": true,
            "description": "Enable decision ledger reporting module."
          }
        }
      },
      "compaction": {
        "type": "object",
        "additionalProperties": false,
        "description": "Compaction and summary controls for the proxy runtime pipeline.",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "autoForkOnPolicy": {
            "type": "boolean",
            "default": true,
            "description": "Apply generated compaction plans by forking a new physical session branch."
          },
          "summaryGenerationMode": {
            "type": "string",
            "enum": ["llm_full_context", "heuristic"],
            "default": "heuristic"
          },
          "summaryFallbackToHeuristic": {
            "type": "boolean",
            "default": true
          },
          "summaryMaxOutputTokens": {
            "type": "number",
            "description": "Max output tokens for summary sidecar generation."
          },
          "includeAssistantReply": {
            "type": "boolean",
            "default": true
          },
          "summaryPrompt": {
            "type": "string",
            "description": "Inline summary prompt override used by the summary module."
          },
          "summaryPromptPath": {
            "type": "string",
            "description": "Path to a custom summary prompt file."
          },
          "resumePrefixPrompt": {
            "type": "string",
            "description": "Inline resume-prefix prompt override used when seeding compacted branches."
          },
          "resumePrefixPromptPath": {
            "type": "string",
            "description": "Path to a custom resume-prefix prompt file."
          },
          "compactionCooldownTurns": {
            "type": "number",
            "description": "Cooldown turns after a compaction request before another request is allowed."
          },
          "turnLocalCompaction": {
            "type": "object",
            "additionalProperties": false,
            "description": "Turn-local compaction settings for archiving tool results that have been consumed by subsequent writes.",
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": false,
                "description": "Enable turn-local compaction."
              },
              "archiveDir": {
                "type": "string",
                "description": "Directory to store archived tool results."
              }
            }
          }
        }
      },
      "handoff": {
        "type": "object",
        "additionalProperties": false,
        "description": "Task handoff generation controls for future sub-agent or continuation workflows.",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "handoffGenerationMode": {
            "type": "string",
            "enum": ["llm_full_context", "heuristic"],
            "default": "heuristic"
          },
          "handoffFallbackToHeuristic": {
            "type": "boolean",
            "default": true
          },
          "handoffMaxOutputTokens": {
            "type": "number",
            "description": "Max output tokens for handoff sidecar generation."
          },
          "includeAssistantReply": {
            "type": "boolean",
            "default": true
          },
          "handoffPrompt": {
            "type": "string",
            "description": "Inline handoff prompt override used by the handoff module."
          },
          "handoffPromptPath": {
            "type": "string",
            "description": "Path to a custom handoff prompt file."
          },
          "handoffCooldownTurns": {
            "type": "number",
            "description": "Cooldown turns after a handoff request before another request is allowed."
          }
        }
      },
      "eviction": {
        "type": "object",
        "additionalProperties": false,
        "description": "Eviction policy interface scaffold. Current runtime behavior is noop; fields are reserved for upcoming eviction implementations.",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "policy": {
            "type": "string",
            "enum": ["noop", "lru", "lfu", "gdsf", "model_scored"],
            "default": "noop"
          },
          "maxCandidateBlocks": {
            "type": "number",
            "description": "Reserved upper bound for candidate blocks when eviction planner is enabled."
          },
          "minBlockChars": {
            "type": "number",
            "description": "Reserved minimum chars for a message/block to be considered by eviction planner."
          },
          "replacementMode": {
            "type": "string",
            "enum": ["pointer_stub", "drop"],
            "default": "pointer_stub",
            "description": "How canonical task eviction replaces archived content: keep a pointer stub or drop the task bundle entirely."
          }
        }
      },
      "taskStateEstimator": {
        "type": "object",
        "additionalProperties": false,
        "description": "Incremental task-state estimator settings used to maintain session task lifecycle and drive registry-backed eviction.",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "baseUrl": {
            "type": "string",
            "description": "OpenAI-compatible base URL for the task-state estimator model."
          },
          "apiKey": {
            "type": "string",
            "sensitive": true,
            "description": "API key used for task-state estimator requests."
          },
          "model": {
            "type": "string",
            "description": "Model name used by the task-state estimator."
          },
          "requestTimeoutMs": {
            "type": "number",
            "default": 60000,
            "description": "HTTP timeout for task-state estimator requests."
          },
          "batchTurns": {
            "type": "number",
            "default": 5,
            "description": "Minimum pending raw turns required before running one estimator update."
          },
          "evictionLookaheadTurns": {
            "type": "number",
            "default": 3,
            "description": "Hint horizon used when deciding whether a completed task can move to evictable."
          },
          "lifecycleMode": {
            "type": "string",
            "enum": ["coupled", "decoupled"],
            "default": "coupled",
            "description": "Whether the estimator directly predicts evictable or only predicts active/completed."
          },
          "evictionPromotionPolicy": {
            "type": "string",
            "enum": ["fifo"],
            "default": "fifo",
            "description": "Promotion policy used in decoupled mode for completed -> evictable."
          },
          "evictionPromotionHotTailSize": {
            "type": "number",
            "default": 1,
            "description": "How many most-recently completed tasks remain hot in completed state before FIFO promotion moves older ones to evictable."
          },
          "inputMode": {
            "type": "string",
            "enum": ["sliding_window", "completed_summary_plus_active_turns"],
            "default": "sliding_window",
            "description": "Estimator input construction mode. sliding_window feeds only the pending turn window; completed_summary_plus_active_turns feeds summaries of completed tasks plus all turns for unresolved tasks."
          }
        }
      },
      "semanticReduction": {
        "type": "object",
        "additionalProperties": false,
        "description": "Optional semantic LLMLingua2 reduction settings for after-call compression.",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "pythonBin": {
            "type": "string",
            "description": "Python executable used to run the LLMLingua2 worker."
          },
          "timeoutMs": {
            "type": "number",
            "default": 120000
          },
          "llmlinguaModelPath": {
            "type": "string",
            "description": "Local path to the LLMLingua2 token-classification model."
          },
          "targetRatio": {
            "type": "number",
            "description": "Target semantic keep ratio between 0.05 and 0.95."
          },
          "minInputChars": {
            "type": "number",
            "description": "Minimum response length before semantic reduction is attempted."
          },
          "minSavedChars": {
            "type": "number",
            "description": "Minimum saved characters required to accept semantic reduction."
          },
          "preselectRatio": {
            "type": "number",
            "description": "Chunk preselection ratio before LLMLingua2 compression."
          },
          "maxChunkChars": {
            "type": "number",
            "description": "Chunk size used by semantic reduction worker."
          },
          "embedding": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "provider": {
                "type": "string",
                "enum": ["local", "api", "none"],
                "default": "none"
              },
              "modelPath": {
                "type": "string",
                "description": "Local path to the embedding model when provider=local."
              },
              "apiBaseUrl": {
                "type": "string",
                "description": "OpenAI-compatible embeddings base URL when provider=api."
              },
              "apiKey": {
                "type": "string",
                "sensitive": true,
                "description": "API key for embeddings when provider=api."
              },
              "apiModel": {
                "type": "string",
                "description": "Embedding model name when provider=api."
              },
              "requestTimeoutMs": {
                "type": "number",
                "default": 30000
              }
            }
          }
        }
      },
      "reduction": {
        "type": "object",
        "additionalProperties": false,
        "description": "Reduction engine controls for proxy execution path.",
        "properties": {
          "engine": {
            "type": "string",
            "enum": ["layered"],
            "default": "layered",
            "description": "Reduction delegates pass execution to layers/execution pipeline."
          },
          "triggerMinChars": {
            "type": "number",
            "description": "Minimum chars to trigger reduction candidate generation in proxy bridge path."
          },
          "maxToolChars": {
            "type": "number",
            "description": "Target max chars for tool payload trim in layered reduction engine."
          },
          "passes": {
            "type": "object",
            "additionalProperties": false,
            "description": "Per-pass toggles for layered reduction experiments and ablations.",
            "properties": {
              "repeatedReadDedup": {
                "type": "boolean",
                "default": true
              },
              "toolPayloadTrim": {
                "type": "boolean",
                "default": true
              },
              "htmlSlimming": {
                "type": "boolean",
                "default": true
              },
              "execOutputTruncation": {
                "type": "boolean",
                "default": true
              },
              "agentsStartupOptimization": {
                "type": "boolean",
                "default": true
              },
              "memoryFaultRecovery": {
                "type": "boolean",
                "default": true
              }
            }
          },
          "passOptions": {
            "type": "object",
            "additionalProperties": false,
            "description": "Per-pass parameter overrides for thresholds, preview sizes, and recovery behavior.",
            "properties": {
              "repeatedReadDedup": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "enabled": { "type": "boolean", "default": true },
                  "headPreviewSize": { "type": "number" },
                  "tailPreviewSize": { "type": "number" },
                  "noteLabel": { "type": "string" },
                  "archiveDir": { "type": "string" },
                  "keepFirstRead": { "type": "boolean", "default": true }
                }
              },
              "toolPayloadTrim": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "maxChars": { "type": "number" },
                  "noteLabel": { "type": "string" },
                  "stdout": { "type": "object", "additionalProperties": true },
                  "stderr": { "type": "object", "additionalProperties": true },
                  "json": { "type": "object", "additionalProperties": true },
                  "blob": { "type": "object", "additionalProperties": true }
                }
              },
              "htmlSlimming": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "enabled": { "type": "boolean", "default": true },
                  "attributeWhitelist": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              },
              "execOutputTruncation": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "enabled": { "type": "boolean", "default": true },
                  "headPreviewSize": { "type": "number" },
                  "tailPreviewSize": { "type": "number" },
                  "noteLabel": { "type": "string" },
                  "archiveDir": { "type": "string" },
                  "toolThresholds": {
                    "type": "object",
                    "additionalProperties": { "type": "number" }
                  }
                }
              },
              "agentsStartupOptimization": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "enabled": { "type": "boolean", "default": true }
                }
              },
              "memoryFaultRecovery": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "enabled": { "type": "boolean", "default": true },
                  "noteLabel": { "type": "string" },
                  "stateDir": { "type": "string" },
                  "maxRecoveriesPerTurn": { "type": "number" }
                }
              },
              "formatSlimming": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "removeCodeFences": { "type": "boolean", "default": true },
                  "collapseBlankLines": { "type": "boolean", "default": true },
                  "trimTrailingSpaces": { "type": "boolean", "default": true }
                }
              },
              "semanticLlmlingua2": {
                "type": "object",
                "additionalProperties": true
              },
              "formatCleaning": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "enabled": { "type": "boolean", "default": true }
                }
              },
              "pathTruncation": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "enabled": { "type": "boolean", "default": true },
                  "maxPathLength": { "type": "number" }
                }
              },
              "imageDownsample": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "enabled": { "type": "boolean", "default": true },
                  "maxImageSizeKB": { "type": "number" },
                  "maxSvgSizeKB": { "type": "number" }
                }
              },
              "lineNumberStrip": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "enabled": { "type": "boolean", "default": true }
                }
              }
            }
          }
        }
      }
    }
  },
  "uiHints": {
    "enabled": {
      "label": "Enabled"
    },
    "logLevel": {
      "label": "Log Level"
    },
    "proxyBaseUrl": {
      "label": "Proxy Base URL",
      "placeholder": "http://127.0.0.1:8787/v1"
    },
    "proxyApiKey": {
      "label": "Proxy API Key",
      "sensitive": true
    },
    "stateDir": {
      "label": "State Directory"
    },
    "debugTapProviderTraffic": {
      "label": "Debug Tap Provider Traffic"
    },
    "debugTapPath": {
      "label": "Debug Tap Path"
    },
    "proxyAutostart": {
      "label": "Proxy Autostart"
    },
    "proxyPort": {
      "label": "Proxy Port"
    },
    "proxyMode": {
      "label": "Proxy Mode"
    },
    "hooks": {
      "label": "Hooks"
    },
    "contextEngine": {
      "label": "Context Engine"
    },
    "compaction": {
      "label": "Compaction"
    },
    "taskStateEstimator": {
      "label": "Task State Estimator"
    },
    "handoff": {
      "label": "Handoff"
    },
    "semanticReduction": {
      "label": "Semantic Reduction"
    },
    "reduction": {
      "label": "Reduction"
    }
  }
}

{
  "name": "@tokenpilot/claude-code-adapter",
  "version": "0.1.0",
  "description": "TokenPilot adapter for Claude Code via an Anthropic-compatible gateway.",
  "main": "dist/index.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zjunlp/LightMem2.git",
    "directory": "components/tokenpilot/adapters/claude-code"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@tokenpilot/decision": "workspace:*",
    "@tokenpilot/host-adapter": "workspace:*",
    "@tokenpilot/kernel": "workspace:*",
    "@tokenpilot/mcp": "workspace:*",
    "@tokenpilot/product-surface": "workspace:*",
    "@tokenpilot/runtime-core": "workspace:*"
  },
  "scripts": {
    "build": "tsx build.ts",
    "doctor:claude-code": "node --import tsx scripts/doctor-claude-code.ts",
    "install:claude-code": "node --import tsx scripts/install-claude-code.ts",
    "report-cache-audit:claude-code": "node --import tsx scripts/report-cache-audit-claude-code.ts",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "esbuild": "^0.25.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "claude-code",
    "anthropic-messages",
    "tokenpilot",
    "context-management",
    "gateway"
  ]
}

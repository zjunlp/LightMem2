{
  "name": "tokenpilot",
  "version": "0.1.0",
  "description": "TokenPilot plugin for OpenClaw: routing hooks and token-efficiency runtime controls.",
  "main": "dist/index.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zjunlp/LightMem2.git",
    "directory": "components/tokenpilot/adapters/openclaw"
  },
  "files": [
    "dist/index.js",
    "dist/index.js.map",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@tokenpilot/decision": "workspace:*",
    "@tokenpilot/host-adapter": "workspace:*",
    "@tokenpilot/history": "workspace:*",
    "@tokenpilot/kernel": "workspace:*",
    "@tokenpilot/memory": "workspace:*",
    "@tokenpilot/product-surface": "workspace:*",
    "@tokenpilot/runtime-core": "workspace:*"
  },
  "scripts": {
    "build": "tsx build.ts",
    "test": "node scripts/run-tests.mjs",
    "doctor:openclaw": "node --import tsx scripts/doctor-openclaw.ts",
    "report-cache-audit:openclaw": "node --import tsx scripts/report-cache-audit-openclaw.ts",
    "pack:release": "bash ./scripts/pack_release.sh",
    "install:release": "bash ./scripts/install_release.sh",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "esbuild": "^0.25.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "tokenpilot",
    "llm-routing",
    "token-efficiency"
  ]
}

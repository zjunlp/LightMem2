{
  "name": "@lightmem2/runtime-core",
  "version": "0.1.0",
  "private": true,
  "lightmem2": {
    "role": "foundation"
  },
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "pnpm exec node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@lightmem2/artifact-store": "workspace:*",
    "@lightmem2/kernel": "workspace:*"
  }
}

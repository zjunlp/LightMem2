{
  "name": "@tokenpilot/cli",
  "version": "0.1.0",
  "private": true,
  "lightmem2": {
    "role": "product"
  },
  "type": "commonjs",
  "main": "dist/cli.js",
  "bin": {
    "lightmem2": "dist/cli.js"
  },
  "scripts": {
    "build": "tsx build.ts",
    "install:bin": "bash ./scripts/install-cli.sh",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@tokenpilot/decision": "workspace:*",
    "@tokenpilot/host-adapter": "workspace:*",
    "@tokenpilot/product-surface": "workspace:*",
    "@tokenpilot/stabilizer": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "^0.25.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
